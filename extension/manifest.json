{
  "manifest_version": 3,
  "name": "Edvenswa AI Tracker",
  "version": "0.1.0",
  "description": "Tracks time spent on third-party AI sites and reports it to your Edvenswa AI Tracker dashboard.",
  "permissions": ["storage", "alarms", "tabs"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://notebooklm.google.com/*",
    "https://*.perplexity.ai/*",
    "https://copilot.microsoft.com/*",
    "https://*.deepseek.com/*",
    "https://grok.com/*",
    "https://*.x.ai/*",
    "https://poe.com/*",
    "https://*.character.ai/*",
    "https://*.you.com/*",
    "https://*.mistral.ai/*",
    "https://kimi.com/*",
    "https://www.kimi.com/*",
    "https://kimi.moonshot.cn/*",
    "https://chat.qwen.ai/*",
    "https://qwen.ai/*",
    "https://tongyi.aliyun.com/*",
    "https://huggingface.co/chat/*",
    "https://pi.ai/*",
    "https://www.phind.com/*",
    "https://phind.com/*",
    "https://meta.ai/*",
    "https://www.meta.ai/*",
    "https://groq.com/*",
    "https://chat.groq.com/*",
    "https://coral.cohere.com/*",
    "https://aitracker.edvenswa.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "ai-tracker@edvenswa.com",
      "strict_min_version": "115.0"
    },
    "safari": {
      "strict_min_version": "16.4"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://notebooklm.google.com/*",
        "https://*.perplexity.ai/*",
        "https://copilot.microsoft.com/*",
        "https://*.deepseek.com/*",
        "https://grok.com/*",
        "https://*.x.ai/*",
        "https://poe.com/*",
        "https://*.character.ai/*",
        "https://*.you.com/*",
        "https://*.mistral.ai/*",
        "https://kimi.com/*",
        "https://www.kimi.com/*",
        "https://kimi.moonshot.cn/*",
        "https://chat.qwen.ai/*",
        "https://qwen.ai/*",
        "https://tongyi.aliyun.com/*",
        "https://huggingface.co/chat/*",
        "https://pi.ai/*",
        "https://www.phind.com/*",
        "https://phind.com/*",
        "https://meta.ai/*",
        "https://www.meta.ai/*",
        "https://groq.com/*",
        "https://chat.groq.com/*",
        "https://coral.cohere.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://aitracker.edvenswa.ai/*"
      ],
      "js": ["dashboard-bridge.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Edvenswa AI Tracker"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "edven-image.png",
    "48": "edven-image.png",
    "128": "edven-image.png"
  }
}
