{
  "manifest_version": 3,
  "name": "Edvenswa AI Tracker",
  "version": "0.1.0",
  "description": "Tracks time spent on third-party AI sites and reports it to your Edvenswa AI Tracker dashboard.",
  "permissions": ["storage", "alarms", "tabs"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://claude.ai/*",
    "https://gemini.google.com/*",
    "https://www.perplexity.ai/*",
    "https://copilot.microsoft.com/*",
    "https://chat.deepseek.com/*",
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*",
    "https://localhost:3000/*",
    "http://31.97.206.219:9031/*"
  ],
  "background": {
    "service_worker": "background.js",
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "ai-tracker@edvenswa.com",
      "strict_min_version": "115.0"
    },
    "safari": {
      "strict_min_version": "16.4"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://claude.ai/*",
        "https://gemini.google.com/*",
        "https://www.perplexity.ai/*",
        "https://copilot.microsoft.com/*",
        "https://chat.deepseek.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*",
        "https://localhost:3000/*",
        "http://31.97.206.219:9031/*"
      ],
      "js": ["dashboard-bridge.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Edvenswa AI Tracker"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "edven-image.png",
    "48": "edven-image.png",
    "128": "edven-image.png"
  }
}
