# --- PostgreSQL ---
# Fill in the values below. Leave DATABASE_URL blank — it's built from these.
PGHOST=
PGPORT=
PGUSER=
PGPASSWORD=
PGDATABASE=

# Optional override. If set, takes precedence over the PG* fields above.
DATABASE_URL=


# Iron session secret (>= 32 chars).
SESSION_SECRET=

NODE_ENV=development

# --- Browser extension ---
# Public origin of this app. Used as the serverUrl handed to the extension
# during provisioning. Defaults to http://localhost:3000 if empty.
# The extension popup's Tracking switch opens ${NEXT_PUBLIC_APP_ORIGIN}/extension/connect
# to perform the handshake — make sure this matches one of the entries in
# extension/manifest.json's `externally_connectable.matches`.
NEXT_PUBLIC_APP_ORIGIN=
